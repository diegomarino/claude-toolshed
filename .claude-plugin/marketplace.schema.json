{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "marketplace.schema.json",
  "title": "Claude Code Marketplace Schema",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Marketplace identifier (kebab-case, no spaces).",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "version": { "type": "string" },
        "pluginRoot": {
          "type": "string",
          "description": "Base directory prepended to relative plugin source paths."
        }
      },
      "additionalProperties": false
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginEntry"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "pluginEntry": {
      "type": "object",
      "required": ["name", "source"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Plugin identifier (kebab-case, no spaces).",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "source": {
          "description": "Where to fetch the plugin from.",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/pluginSource"
            }
          ]
        },
        "category": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "strict": {
          "type": "boolean",
          "description": "When true, plugin.json must exist in the plugin source."
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "author": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "url": { "type": "string", "format": "uri" }
          },
          "additionalProperties": false
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "license": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "commands": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "agents": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "hooks": {
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        },
        "mcpServers": {
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        },
        "lspServers": {
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        }
      },
      "additionalProperties": true
    },
    "pluginSource": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["github", "url"]
        },
        "repo": {
          "type": "string",
          "description": "GitHub repository in owner/repo format."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Git repository URL."
        },
        "ref": {
          "type": "string",
          "description": "Git branch or tag."
        },
        "sha": {
          "type": "string",
          "description": "Full 40-character git commit SHA."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "source": { "const": "github" } } },
          "then": { "required": ["repo"] }
        },
        {
          "if": { "properties": { "source": { "const": "url" } } },
          "then": { "required": ["url"] }
        }
      ]
    }
  }
}
